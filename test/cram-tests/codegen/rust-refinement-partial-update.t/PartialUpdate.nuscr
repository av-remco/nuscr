(*# RefinementTypes #*)

global protocol PartialUpdate(role C, role S) {
  rec loop [total<C, S>: (total: int{total < 100}) = 0, snd<C,S>: (snd:int) = 0] {
    choice at C {
      add(x: int{x > 0}, y: int{y > 0}) from C to S;
      sum(r: int{r = x + y}) from S to C;
      continue loop [total + r];
    } or {
      bye() from C to S;
      bye() from S to C;
    }
  }
}
